pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install dependencies') {
            steps {
                sh '''
                    docker exec php_fpm_petProject bash -lc "
                        cd /var/www/html &&
                        composer install --no-interaction --prefer-dist
                    "
                '''
            }
        }

        stage('Lint (PHPCS)') {
            steps {
                sh '''
                    docker exec php_fpm_petProject bash -lc "
                        cd /var/www/html &&
                        vendor/bin/phpcs
                    "
                '''
            }
        }

        stage('Static Analysis (PHPStan)') {
            steps {
                sh '''
                    docker exec php_fpm_petProject bash -lc "
                        cd /var/www/html &&
                        vendor/bin/phpstan analyse
                    "
                '''
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                    docker exec php_fpm_petProject bash -lc "
                        cd /var/www/html &&
                        vendor/bin/phpunit --log-junit tests/_reports/junit.xml
                    "
                '''
            }
        }
    }

    post {
        always {
            junit 'laravel-app/tests/_reports/*.xml'
        }
    }
}
