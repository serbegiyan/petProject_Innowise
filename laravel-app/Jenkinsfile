pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'pwd'
            }
        }

        stage('Install dependencies') {
            steps {
                sh 'docker exec php_fpm_petProject composer install --no-interaction --prefer-dist'
            }
        }

        stage('Check Style') {
            steps {
                sh 'docker exec php_fpm_petProject vendor/bin/pint --test'
            }
        }
        stage('PHPStan') {
            steps {
                sh 'docker exec php_fpm_petProject vendor/bin/phpstan analyse --memory-limit=1G'
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                    # Создаем папку заранее, чтобы не было проблем с правами
                    docker exec php_fpm_petProject mkdir -p tests/_reports
                    
                    # Запускаем тесты
                    docker exec php_fpm_petProject vendor/bin/phpunit --log-junit tests/_reports/junit.xml
                    
                    # Даем права на чтение для Jenkins (UID 1000)
                    docker exec -u root php_fpm_petProject chown -R 1000:1000 tests/_reports
                '''
            }
        }
    }

    post {
        always {
            // Теперь путь 'tests/_reports/*.xml' будет верным относительно воркспейса
            junit 'tests/_reports/*.xml'
        }
    }
}