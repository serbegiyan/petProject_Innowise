pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'pwd'
            }
        }

        stage('Install dependencies') {
            steps {
                sh '''
                    docker exec php_fpm_petProject composer install --no-interaction --prefer-dist
                    docker exec php_fpm_petProject php artisan key:generate --env=testing || true
                '''
            }
        }

        stage('Check Style') {
            steps {
                sh 'docker exec php_fpm_petProject vendor/bin/pint --test'
            }
        }
        
        stage('PHPStan') {
            steps {
                sh '''
                    # 1. Очищаем кэш PHPStan, чтобы он не подтягивал старые ошибки
                    docker exec php_fpm_petProject vendor/bin/phpstan clear-result-cache
                    
                    # 2. Генерируем хелперы прямо в контейнере (на случай, если база нужна для анализа)
                    docker exec php_fpm_petProject php artisan ide-helper:generate
                    docker exec php_fpm_petProject php artisan ide-helper:models --nowrite
                    
                    # 3. Запускаем анализ
                    docker exec php_fpm_petProject vendor/bin/phpstan analyse --memory-limit=1G
                '''
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                    # 1. Создаем папку и запускаем тесты внутри PHP контейнера
                    docker exec php_fpm_petProject mkdir -p tests/_reports
                    docker exec php_fpm_petProject vendor/bin/phpunit --log-junit tests/_reports/junit.xml
                    
                    # 2. СОЗДАЕМ папку в самом Jenkins (Workspace)
                    mkdir -p tests/_reports
                    
                    # 3. КОПИРУЕМ файл из контейнера наружу в Jenkins
                    docker cp php_fpm_petProject:/var/www/html/tests/_reports/junit.xml ./tests/_reports/junit.xml
                '''
            }
        }
    }

    post {
        always {
            junit 'tests/_reports/*.xml'
        }
         success {
            step([$class: 'GitHubCommitStatusSetter', statusResultSource: [$class: 'DefaultStatusResultSource']])
        }
        failure {
            step([$class: 'GitHubCommitStatusSetter', statusResultSource: [$class: 'DefaultStatusResultSource']])
        }
    }
}