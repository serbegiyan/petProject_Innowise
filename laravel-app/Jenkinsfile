pipeline {
    // Используем Docker-образ как среду выполнения. 
    // Jenkins сам запустит контейнер, смонтирует рабочую директорию и удалит его после билда.
    agent {
        docker {
            image 'php:8.5-fpm' // Укажи свою версию PHP
            args '-u root'      // Нужно для прав на запись в mounted volume
        }
    }

    environment {
        // Отключаем интерактивность для composer и фиксируем пути
        COMPOSER_ALLOW_SUPERUSER = "1"
        REPORTS_DIR = "tests/_reports"
    }

    stages {
        stage('Prepare Environment') {
            steps {
                // Устанавливаем системные зависимости и Composer внутри агента
                sh '''
                    apt-get update && apt-get install -y unzip git
                    curl -sS https://getcomposer.org | php -- --install-dir=/usr/local/bin --filename=composer
                '''
            }
        }

        stage('Install dependencies') {
            steps {
                sh 'composer install --no-interaction --prefer-dist --optimize-autoloader'
            }
        }

        stage('Lint & Static Analysis') {
            parallel {
                stage('Check Style') {
                    steps {
                        // Используем --test для Pint, чтобы он не менял файлы, а только проверял
                        sh 'vendor/bin/pint --test'
                        sh 'vendor/bin/phpcs'
                    }
                }
                stage('PHPStan') {
                    steps {
                        sh 'vendor/bin/phpstan analyse --memory-limit=1G'
                    }
                }
            }
        }

        stage('Run Tests') {
            steps {
                // Создаем директорию для отчетов, если её нет
                sh "mkdir -p ${REPORTS_DIR}"
                sh "vendor/bin/phpunit --log-junit ${REPORTS_DIR}/junit.xml"
            }
        }
    }

    post {
        always {
            // Собираем отчеты (путь теперь совпадает с тем, что в тестах)
            junit "tests/_reports/*.xml"
            
            // Очищаем рабочее пространство, чтобы не забивать диск агента
            cleanWs()
        }
    }
}
