# Скопируйте: cp .env.example .env && php artisan key:generate
# Docker Compose (petProject): хосты сервисов — имена контейнеров (mysql_db, redis, rabbitmq, localstack).
# С хоста (без Docker): 127.0.0.1 и проброшенные порты из docker-compose.yml.

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# MySQL (docker-compose: mysql_db)
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql_db
DB_PORT=3306
DB_DATABASE=Laravel_petProject
DB_USERNAME=user
DB_PASSWORD=password

# ------------------------------------------------------------------------------
# Session & cache (Redis: docker-compose redis)
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
# SESSION_DRIVER=redis
# SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
# CACHE_STORE=database
# CACHE_PREFIX=

# ------------------------------------------------------------------------------
# Queue (RabbitMQ: docker-compose rabbitmq, worker: php_worker_petProject)
# ------------------------------------------------------------------------------
QUEUE_CONNECTION=rabbitmq
# QUEUE_CONNECTION=database
# QUEUE_CONNECTION=sync

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
# RABBITMQ_QUEUE=default

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1

MEMCACHED_HOST=127.0.0.1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ------------------------------------------------------------------------------
# S3 exports via LocalStack (docker-compose localstack, init: init-s3.sh)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=catalog-exports
AWS_ENDPOINT=http://localstack:4566
# URL для ссылок в браузере с хоста (LocalStack проброшен на 127.0.0.1:4566)
AWS_URL=http://localhost:4566/catalog-exports
AWS_USE_PATH_STYLE_ENDPOINT=true

# ------------------------------------------------------------------------------
# Mail (LocalStack SES в dev; bucket/catalog — см. init-s3.sh)
# ------------------------------------------------------------------------------
MAIL_MAILER=ses
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="admin@admin.com"
MAIL_FROM_NAME="${APP_NAME}"

CATALOG_EXPORT_RECIPIENT=admin@admin.com

VITE_APP_NAME="${APP_NAME}"
