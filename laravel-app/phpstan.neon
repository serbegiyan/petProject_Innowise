includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 4

    paths:
        - app
        - routes

    excludePaths:
        - database
        - bootstrap
        - storage
        - vendor

    ignoreErrors:
        - '#Facade root not set#'
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Builder::#'
        - '#Access to an undefined property Illuminate\\Database\\Eloquent\\Model::#'

    parallel:
        maximumNumberOfProcesses: 4

