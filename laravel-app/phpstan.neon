includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 3
    
    paths:
        - app
        - routes

    checkGenericClassInNonGenericObjectType: false
    checkMissingIterableValueType: false

    scanFiles:
        - _ide_helper_models.php

    excludePaths:
        - database
        - bootstrap
        - storage
        - vendor

    parallel:
        maximumNumberOfProcesses: 4

