<?xml version="1.0"?>
<ruleset name="Laravel Project Standards">

    <description>PHPCS rules for Laravel project</description>

    <!-- Основной стандарт -->
    <rule ref="PSR12"/>

    <!-- Проверяем только эти директории -->
    <file>app</file>
    <file>routes</file>
    <file>tests</file>

    <!-- Исключаем системные директории -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/storage/*</exclude-pattern>
    <exclude-pattern>*/bootstrap/*</exclude-pattern>
    <exclude-pattern>*/database/*</exclude-pattern>

    <!-- 1. Отключаем ограничение длины строки -->
    <rule ref="Generic.Files.LineLength">
        <exclude name="Generic.Files.LineLength.TooLong"/>
    </rule>

    <!-- 2. Разрешаем snake_case в тестах -->
    <rule ref="PSR1.Methods.CamelCapsMethodName">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>

    <!-- 3. Отключаем требование видимости констант -->
    <exclude name="PSR12.Properties.ConstantVisibility"/>

</ruleset>

