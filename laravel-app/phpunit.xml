<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="FILESYSTEM_DISK" value="local"/>
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="AWS_BUCKET" value="test-bucket"/>
        <env name="AWS_DEFAULT_REGION" value="us-east-1"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="APP_KEY" value="base64:+ihRwR0J7Z4xAzVDcpGfOas9XVuVq7gUWycC01z1wqY="/>
        
        <env name="CACHE_STORE" value="redis"/>
        <env name="SESSION_DRIVER" value="redis"/>
        <env name="REDIS_CACHE_DB" value="5"/>
        <env name="REDIS_SESSION_DB" value="6"/>
        <env name="REDIS_HOST" value="redis"/>
        <env name="REDIS_CLIENT" value="phpredis"/>

        <env name="DB_CONNECTION" value="mysql"/>
        <env name="DB_HOST" value="mysql_db"/>
        <env name="DB_DATABASE" value="Laravel_petProject_test"/>
        <env name="DB_USERNAME" value="user"/>
        <env name="DB_PASSWORD" value="password"/>

        <env name="MAIL_MAILER" value="array"/>        
        <env name="QUEUE_CONNECTION" value="rabbitmq"/>
        <env name="RABBITMQ_HOST" value="rabbitmq"/>
        <env name="RABBITMQ_QUEUE" value="testing_queue"/>
    
        
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
